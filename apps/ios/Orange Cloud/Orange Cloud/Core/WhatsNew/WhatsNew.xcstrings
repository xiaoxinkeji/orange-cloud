    "直接新建 D1 数据库，或在原样确认库名后安全删除。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create a D1 database, or delete one safely after confirming its exact name."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "直接建立 D1 資料庫，或在原樣確認資料庫名稱後安全刪除。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "直接建立 D1 資料庫，或在原樣確認資料庫名稱後安全刪除。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "D1 データベースを作成したり、データベース名を正確に確認してから安全に削除したりできます。"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea una base de datos D1, o elimínala de forma segura tras confirmar su nombre exacto."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "D1 데이터베이스를 만들거나, 데이터베이스 이름을 그대로 확인한 뒤 안전하게 삭제하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Crie um banco de dados D1 ou exclua-o com segurança após confirmar o nome exato."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Crie uma base de dados D1 ou elimine-a com segurança após confirmar o nome exato."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstelle eine D1-Datenbank oder lösche eine sicher, nachdem du ihren genauen Namen bestätigt hast."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Créez une base de données D1, ou supprimez-en une en toute sécurité après avoir confirmé son nom exact."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنشئ قاعدة بيانات D1، أو احذف واحدة بأمان بعد تأكيد اسمها بالضبط."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir D1 veritabanı oluşturun veya tam adını doğruladıktan sonra birini güvenle silin."
          }
        }
      }
    },
    "管理 Worker 的环境变量与密钥，随手增删改。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Manage a Worker’s environment variables and secrets — add, edit, and remove on the fly."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "管理 Worker 的環境變數與密鑰，隨手增刪改。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "管理 Worker 的環境變數與密鑰，隨手增刪改。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Worker の環境変数とシークレットを管理し、いつでも追加・編集・削除できます。"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Gestiona las variables de entorno y los secretos de un Worker: agrega, edita y elimina al instante."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Worker의 환경 변수와 시크릿을 관리하고 언제든 추가·편집·삭제하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Gerencie as variáveis de ambiente e os segredos de um Worker: adicione, edite e remova na hora."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Faça a gestão das variáveis de ambiente e dos segredos de um Worker: adicione, edite e remova na hora."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwalte die Umgebungsvariablen und Secrets eines Workers – jederzeit hinzufügen, bearbeiten und entfernen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gérez les variables d’environnement et les secrets d’un Worker — ajoutez, modifiez et supprimez à la volée."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أدِر متغيرات البيئة والأسرار لـ Worker — إضافة وتعديل وحذف في أي وقت."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir Worker’ın ortam değişkenlerini ve gizli bilgilerini yönetin — anında ekleyin, düzenleyin ve kaldırın."
          }
        }
      }
    },
    "管理 workers.dev 子域、自定义域与路由，掌控 Worker 的访问入口。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Manage the workers.dev subdomain, custom domains, and routes to control how a Worker is reached."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "管理 workers.dev 子網域、自訂網域與路由，掌控 Worker 的存取入口。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "管理 workers.dev 子域、自訂域名與路由，掌控 Worker 的存取入口。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "workers.dev サブドメイン、カスタムドメイン、ルートを管理し、Worker へのアクセス経路を制御します。"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Gestiona el subdominio workers.dev, los dominios personalizados y las rutas para controlar cómo se accede a un Worker."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "workers.dev 서브도메인, 사용자 지정 도메인, 라우트를 관리해 Worker 접근 경로를 제어하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Gerencie o subdomínio workers.dev, domínios personalizados e rotas para controlar como um Worker é acessado."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Faça a gestão do subdomínio workers.dev, domínios personalizados e rotas para controlar como um Worker é acedido."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwalte die workers.dev-Subdomain, eigene Domains und Routen, um zu steuern, wie ein Worker erreicht wird."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gérez le sous-domaine workers.dev, les domaines personnalisés et les routes pour contrôler l’accès à un Worker."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أدِر نطاق workers.dev الفرعي والنطاقات المخصصة والمسارات للتحكم في كيفية الوصول إلى Worker."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir Worker’a nasıl erişileceğini denetlemek için workers.dev alt alan adını, özel alan adlarını ve rotaları yönetin."
          }
        }
      }
    },
