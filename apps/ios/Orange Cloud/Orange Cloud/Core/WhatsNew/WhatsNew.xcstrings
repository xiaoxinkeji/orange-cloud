    "开关域名的邮件路由，增删改转发规则，并管理账号内的已验证目的地址。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn Email Routing on or off, create and edit forwarding rules, and manage your account's verified destination addresses."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開關網域的郵件路由，新增、編輯轉寄規則，並管理帳戶內已驗證的目的地址。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "開關域名的郵件路由，新增、編輯轉發規則，並管理帳號內已驗證的目的地址。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ドメインのメールルーティングのオン/オフ、転送ルールの作成・編集、検証済みの目的地アドレスの管理ができます。"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa o desactiva el enrutamiento de correo del dominio, crea y edita reglas de reenvío y gestiona las direcciones de destino verificadas de tu cuenta."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "도메인의 이메일 라우팅을 켜고 끄고, 전달 규칙을 만들고 편집하며, 계정의 확인된 대상 주소를 관리하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative ou desative o roteamento de e-mail do domínio, crie e edite regras de encaminhamento e gerencie os endereços de destino verificados da sua conta."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative ou desative o encaminhamento de correio do domínio, crie e edite regras de reencaminhamento e faça a gestão dos endereços de destino verificados da sua conta."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalte das E-Mail-Routing der Domain ein oder aus, erstelle und bearbeite Weiterleitungsregeln und verwalte die verifizierten Zieladressen deines Kontos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez ou désactivez le routage des e-mails du domaine, créez et modifiez des règles de transfert et gérez les adresses de destination vérifiées de votre compte."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فعّل توجيه البريد للنطاق أو عطّله، وأنشئ قواعد إعادة التوجيه وعدّلها، وأدِر عناوين الوجهة المُتحقَّق منها في حسابك."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alan adının e-posta yönlendirmesini açıp kapatın, iletme kuralları oluşturup düzenleyin ve hesabınızın doğrulanmış hedef adreslerini yönetin."
          }
        }
      }
    },
    "把域名状态与流量概览带上手腕，还能添加到表盘复杂功能随时一瞥。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bring domain status and traffic overview to your wrist, with watch face complications for a glance anytime."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "把網域狀態與流量概覽帶上手腕，還能加入錶面複雜功能隨時一瞥。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "把域名狀態與流量概覽帶上手腕，還能加入錶面複雜功能隨時一瞥。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ドメインの状態とトラフィック概要を手首で確認。文字盤のコンプリケーションでいつでもひと目で。"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Lleva a tu muñeca el estado de los dominios y el resumen de tráfico, con complicaciones en la carátula para verlo de un vistazo."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "도메인 상태와 트래픽 개요를 손목에서 확인하고, 시계 페이스 컴플리케이션으로 언제든 한눈에 볼 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Leve o status dos domínios e o resumo de tráfego para o pulso, com complicações no mostrador para ver num relance."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Leve o estado dos domínios e o resumo de tráfego para o pulso, com complicações no mostrador para ver num relance."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bring Domain-Status und Traffic-Übersicht an dein Handgelenk – mit Komplikationen auf dem Zifferblatt für einen Blick jederzeit."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apportez l’état des domaines et l’aperçu du trafic à votre poignet, avec des complications sur le cadran pour un coup d’œil à tout moment."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انقل حالة النطاقات ونظرة عامة على حركة المرور إلى معصمك، مع تعقيدات على واجهة الساعة لإلقاء نظرة في أي وقت."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alan adı durumunu ve trafik genel görünümünü bileğinize taşıyın; istediğiniz an bir bakış için saat kadranı komplikasyonlarıyla."
          }
        }
      }
    },
    "按 IP、网段、ASN 或国家/地区拦截、质询或放行访问，随时增删规则。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Block, challenge, or allow visitors by IP, IP range, ASN, or country — add and remove rules anytime."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "依 IP、網段、ASN 或國家/地區封鎖、質詢或放行存取，隨時新增或刪除規則。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "按 IP、網段、ASN 或國家/地區封鎖、質詢或放行存取，隨時新增或刪除規則。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "IP、IP 範囲、ASN、国/地域ごとにアクセスをブロック・チャレンジ・許可でき、ルールはいつでも追加・削除できます。"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Bloquea, desafía o permite el acceso por IP, rango de IP, ASN o país, y agrega o elimina reglas cuando quieras."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "IP, IP 범위, ASN 또는 국가/지역별로 접근을 차단·검증·허용하고 규칙을 언제든 추가하거나 삭제하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Bloqueie, desafie ou permita o acesso por IP, intervalo de IP, ASN ou país, e adicione ou remova regras quando quiser."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Bloqueie, desafie ou permita o acesso por IP, intervalo de IP, ASN ou país, e adicione ou remova regras quando quiser."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Blockiere, fordere heraus oder erlaube Besucher nach IP, IP-Bereich, ASN oder Land – Regeln jederzeit hinzufügen oder entfernen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bloquez, défiez ou autorisez les visiteurs par IP, plage d'IP, ASN ou pays, et ajoutez ou supprimez des règles à tout moment."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احظر الزوّار أو تحقّق منهم أو اسمح لهم حسب IP أو نطاق IP أو ASN أو الدولة، وأضِف القواعد أو احذفها في أي وقت."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziyaretçileri IP, IP aralığı, ASN veya ülkeye göre engelleyin, doğrulayın ya da izin verin; kuralları istediğiniz zaman ekleyip kaldırın."
          }
        }
      }
    },
