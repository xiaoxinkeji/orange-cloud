        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "URL'ye göre önbellek temizleme"
          }
        }
      }
    },
    "按 URL 自定义边缘与浏览器缓存时长、绕过缓存，直接在手机上管理缓存规则。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Customize edge and browser cache TTLs per URL or bypass cache entirely — manage cache rules right from your phone."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "依 URL 自訂邊緣與瀏覽器快取時間、略過快取，直接在手機上管理快取規則。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "按 URL 自訂邊緣與瀏覽器緩存時間、繞過緩存，直接在手機上管理緩存規則。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "URL ごとにエッジとブラウザーのキャッシュ TTL をカスタマイズしたり、キャッシュをバイパスしたり。キャッシュルールをスマホから管理できます。"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Personaliza el TTL de caché en el borde y el navegador por URL u omite la caché por completo: administra las reglas de caché desde tu teléfono."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "URL별로 엣지·브라우저 캐시 TTL을 설정하거나 캐시를 우회하세요. 캐시 규칙을 휴대폰에서 바로 관리할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Personalize o TTL de cache na borda e no navegador por URL ou ignore o cache por completo — gerencie regras de cache direto do celular."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Personalize o TTL de cache na extremidade e no navegador por URL ou ignore o cache por completo — faça a gestão das regras de cache diretamente do telemóvel."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Passe Edge- und Browser-Cache-TTLs pro URL an oder umgehe den Cache ganz – verwalte Cache-Regeln direkt vom Handy."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Personnalisez les TTL de cache edge et navigateur par URL ou contournez complètement le cache — gérez les règles de cache depuis votre téléphone."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "خصّص مدة التخزين المؤقت على الحافة والمتصفح لكل عنوان URL أو تجاوز التخزين المؤقت كليًا، وأدِر قواعد التخزين المؤقت من هاتفك."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "URL bazında uç ve tarayıcı önbellek TTL'lerini özelleştirin veya önbelleği tamamen atlayın — önbellek kurallarını telefonunuzdan yönetin."
          }
        }
      }
    },
    "新增德语、法语、阿拉伯语与土耳其语；并改进崩溃诊断，帮助更快定位疑难问题。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Added German, French, Arabic, and Turkish, plus improved crash diagnostics to track down tricky issues faster."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "新增德語、法語、阿拉伯語與土耳其語；並改進當機診斷，協助更快定位疑難問題。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "新增德語、法語、阿拉伯語與土耳其語；並改進崩潰診斷，協助更快定位疑難問題。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ドイツ語・フランス語・アラビア語・トルコ語に対応し、クラッシュ診断も改善して、やっかいな問題をより早く特定できるようにしました。"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Agregamos alemán, francés, árabe y turco, y mejoramos el diagnóstico de fallos para detectar problemas difíciles más rápido."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "독일어, 프랑스어, 아랍어, 터키어를 추가하고 충돌 진단을 개선하여 까다로운 문제를 더 빠르게 찾아냅니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicionamos alemão, francês, árabe e turco, e melhoramos o diagnóstico de falhas para identificar problemas difíceis mais rápido."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicionámos alemão, francês, árabe e turco, e melhorámos o diagnóstico de falhas para identificar problemas difíceis mais depressa."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deutsch, Französisch, Arabisch und Türkisch kommen hinzu, dazu eine verbesserte Absturzdiagnose, um knifflige Probleme schneller aufzuspüren."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajout de l'allemand, du français, de l'arabe et du turc, ainsi qu'un diagnostic de plantage amélioré pour cerner plus vite les problèmes délicats."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضفنا الألمانية والفرنسية والعربية والتركية، وحسّنّا تشخيص الأعطال لتحديد المشكلات الصعبة بشكل أسرع."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Almanca, Fransızca, Arapça ve Türkçe eklendi; ayrıca zorlu sorunları daha hızlı bulmak için çökme tanılaması iyileştirildi."
          }
        }
      }
    },
    "新增西班牙语、韩语、葡萄牙语，现已支持九种语言。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Added Spanish, Korean, and Portuguese — now available in nine languages."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "新增西班牙文、韓文、葡萄牙文，現已支援九種語言。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "新增西班牙文、韓文、葡萄牙文，現已支援九種語言。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スペイン語・韓国語・ポルトガル語を追加し、9言語に対応しました。"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Agregamos español, coreano y portugués: ahora en nueve idiomas."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스페인어, 한국어, 포르투갈어가 추가되어 이제 9개 언어를 지원합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicionamos espanhol, coreano e português — agora em nove idiomas."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicionámos espanhol, coreano e português — agora em nove idiomas."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spanisch, Koreanisch und Portugiesisch hinzugefügt – jetzt in neun Sprachen verfügbar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajout de l’espagnol, du coréen et du portugais — désormais disponible en neuf langues."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أُضيفت الإسبانية والكورية والبرتغالية — متاح الآن بتسع لغات."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İspanyolca, Korece ve Portekizce eklendi — artık dokuz dilde."
          }
        }
      }
    },
    "新建与管理限速规则：按访客 IP 在时间窗内限制请求次数，超限即阻止或质询。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create and manage rate limiting rules: cap requests per visitor IP within a time window, then block or challenge when exceeded."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "新增並管理速率限制規則：依訪客 IP 在時間範圍內限制請求次數，超限即封鎖或質詢。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "新增並管理速率限制規則：依訪客 IP 在時間範圍內限制請求次數，超限即封鎖或質詢。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "レート制限ルールを作成・管理。時間枠内の訪問者 IP ごとのリクエスト数を制限し、超過時にブロックまたはチャレンジを実行します。"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea y gestiona reglas de límite de tasa: limita las solicitudes por IP de visitante en una ventana de tiempo y bloquea o desafía cuando se supera."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "속도 제한 규칙을 만들고 관리하세요. 시간 범위 내 방문자 IP별 요청 수를 제한하고 초과 시 차단하거나 챌린지를 적용합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Crie e gerencie regras de limite de taxa: limite as solicitações por IP de visitante em uma janela de tempo e bloqueie ou desafie ao exceder."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Crie e faça a gestão de regras de limite de taxa: limite os pedidos por IP de visitante numa janela de tempo e bloqueie ou desafie ao exceder."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstelle und verwalte Ratenbegrenzungsregeln: Begrenze Anfragen pro Besucher-IP in einem Zeitfenster und blockiere oder fordere bei Überschreitung heraus."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Créez et gérez des règles de limitation de débit : plafonnez les requêtes par IP de visiteur dans une fenêtre temporelle, puis bloquez ou défiez en cas de dépassement."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنشئ قواعد تحديد المعدل وأدِرها: حُدّ من عدد الطلبات حسب IP الزائر ضمن نافذة زمنية، ثم احظر أو اطلب تحديًا عند التجاوز."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hız sınırı kuralları oluşturun ve yönetin: ziyaretçi IP'si başına istekleri bir zaman aralığında sınırlayın, aşıldığında engelleyin veya doğrulama isteyin."
          }
        }
      }
    },
    "无需清空整站，指定单个或多个 URL 精准刷新缓存；并新增性能与缓存设置页。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Refresh the cache for specific URLs without clearing the whole site — plus a new performance and cache settings page."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "不必清空整站，指定單一或多個 URL 精準刷新快取；並新增效能與快取設定頁。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "不必清空整站，指定單一或多個 URL 精準刷新緩存；並新增效能與緩存設定頁。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サイト全体を消さずに、特定の URL だけキャッシュを更新できます。パフォーマンスとキャッシュの設定ページも追加しました。"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualiza la caché de URLs específicas sin borrar todo el sitio, y estrena una página de ajustes de rendimiento y caché."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사이트 전체를 비우지 않고 특정 URL의 캐시만 새로 고치세요. 성능 및 캐시 설정 페이지도 추가되었습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Atualize o cache de URLs específicas sem limpar o site inteiro — e conte com uma nova página de configurações de desempenho e cache."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Atualize a cache de URLs específicos sem limpar o site inteiro — e conte com uma nova página de definições de desempenho e cache."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktualisiere den Cache gezielt für einzelne URLs, ohne die ganze Website zu leeren – dazu eine neue Seite für Leistungs- und Cache-Einstellungen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualisez le cache d'URL précises sans vider tout le site, avec en prime une nouvelle page de réglages de performance et de cache."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حدّث ذاكرة التخزين المؤقت لعناوين URL محددة دون مسح الموقع بأكمله — مع صفحة جديدة لإعدادات الأداء والتخزين المؤقت."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tüm siteyi temizlemeden belirli URL'lerin önbelleğini yenileyin; ayrıca yeni bir performans ve önbellek ayarları sayfası eklendi."
          }
        }
      }
    },
