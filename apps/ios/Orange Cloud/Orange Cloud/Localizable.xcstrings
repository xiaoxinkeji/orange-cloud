    "设置 = 覆盖或新增，追加 = 多值追加，删除 = 移除该头。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعيين = استبدال أو إضافة، إلحاق = إضافة قيمة أخرى، إزالة = حذف الترويسة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Setzen = überschreiben oder hinzufügen, Anhängen = weiteren Wert hinzufügen, Entfernen = Header löschen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set = overwrite or add, Append = add another value, Remove = delete the header."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Establecer = sobrescribir o añadir, Anexar = añadir otro valor, Eliminar = quitar el encabezado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Définir = écraser ou ajouter, Ajouter = ajouter une autre valeur, Supprimer = supprimer l’en-tête."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定＝上書きまたは追加、追加＝値を複数追加、削除＝そのヘッダーを削除。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정 = 덮어쓰기 또는 추가, 추가 = 값 여러 개 추가, 삭제 = 해당 헤더 제거."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Definir = sobrescrever ou adicionar, Anexar = adicionar outro valor, Remover = excluir o cabeçalho."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Definir = substituir ou adicionar, Anexar = adicionar outro valor, Remover = eliminar o cabeçalho."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ayarla = üzerine yaz veya ekle, Ekle = başka bir değer ekle, Kaldır = başlığı sil."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "設定 = 覆寫或新增，追加 = 多值追加，刪除 = 移除該標頭。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "設定 = 覆寫或新增，追加 = 多值追加，刪除 = 移除該標頭。"
          }
        }
      }
    },
    "访客到 Cloudflare 加密，Cloudflare 到源站不加密。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يشفّر حركة المرور بين الزوار وCloudflare، لكن ليس بين Cloudflare والمصدر."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verschlüsselt den Verkehr zwischen Besuchern und Cloudflare, aber nicht zwischen Cloudflare und deinem Origin."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Encrypts traffic between visitors and Cloudflare, but not between Cloudflare and your origin."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Cifra el tráfico entre los visitantes y Cloudflare, pero no entre Cloudflare y tu servidor de origen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chiffre le trafic entre les visiteurs et Cloudflare, mais pas entre Cloudflare et votre origine."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "訪問者と Cloudflare 間は暗号化し、Cloudflare とオリジン間は暗号化しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "방문자와 Cloudflare 간은 암호화하지만 Cloudflare와 원본 서버 간은 암호화하지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Criptografa o tráfego entre os visitantes e a Cloudflare, mas não entre a Cloudflare e sua origem."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Encripta o tráfego entre os visitantes e a Cloudflare, mas não entre a Cloudflare e a origem."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziyaretçiler ile Cloudflare arasındaki trafiği şifreler, ancak Cloudflare ile kaynağınız arasındakini şifrelemez."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "訪客到 Cloudflare 加密，Cloudflare 到源站不加密。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "訪客到 Cloudflare 加密，Cloudflare 到源站不加密。"
          }
        }
      }
    },
    "访客浏览器缓存内容的时长。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المدة التي تخزّن فيها متصفّحات الزوّار المحتوى مؤقتًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie lange die Browser der Besucher den Inhalt zwischenspeichern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How long visitors' browsers cache the content."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuánto tiempo los navegadores de los visitantes almacenan el contenido en caché."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Durée de mise en cache du contenu par les navigateurs des visiteurs."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "訪問者のブラウザーがコンテンツをキャッシュする期間です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "방문자의 브라우저가 콘텐츠를 캐시하는 기간입니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Por quanto tempo os navegadores dos visitantes mantêm o conteúdo em cache."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Durante quanto tempo os navegadores dos visitantes mantêm o conteúdo em cache."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziyaretçilerin tarayıcılarının içeriği ne kadar süre önbelleğe alacağı."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "訪客瀏覽器緩存內容的時長。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "訪客瀏覽器快取內容的時長。"
          }
        }
      }
    },
