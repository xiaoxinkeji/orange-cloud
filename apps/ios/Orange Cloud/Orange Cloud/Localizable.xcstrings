    "输入你已注册的根域名（如 example.com），无需带 www 或 https://。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أدخل نطاقًا جذريًا تملكه بالفعل (مثل example.com) — دون www أو https://."
          }
        },
        "de": {
          "stringUnit": {
