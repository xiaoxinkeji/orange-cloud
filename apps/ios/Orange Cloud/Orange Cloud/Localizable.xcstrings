    "Cloudflare 尚未返回名称服务器，请稍后在域名详情或 Cloudflare Dashboard 查看。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم تُرجِع Cloudflare خوادم الأسماء بعد. تحقق لاحقًا من تفاصيل النطاق أو لوحة تحكم Cloudflare."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflare hat die Nameserver noch nicht zurückgegeben. Sieh später in den Domain-Details oder im Cloudflare-Dashboard nach."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflare hasn’t returned the name servers yet. Check back later in the domain details or the Cloudflare dashboard."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflare aún no ha devuelto los servidores de nombres. Vuelve a consultarlo más tarde en los detalles del dominio o en el panel de Cloudflare."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflare n’a pas encore renvoyé les serveurs de noms. Vérifiez plus tard dans les détails du domaine ou le tableau de bord Cloudflare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflare はまだネームサーバを返していません。後ほどドメインの詳細または Cloudflare ダッシュボードで確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflare가 아직 네임서버를 반환하지 않았습니다. 나중에 도메인 세부 정보나 Cloudflare 대시보드에서 확인하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A Cloudflare ainda não retornou os servidores de nomes. Verifique mais tarde nos detalhes do domínio ou no painel da Cloudflare."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A Cloudflare ainda não devolveu os servidores de nomes. Verifique mais tarde nos detalhes do domínio ou no painel da Cloudflare."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflare ad sunucularını henüz döndürmedi. Daha sonra alan adı ayrıntılarından veya Cloudflare panosundan kontrol edin."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflare 尚未回傳名稱伺服器，請稍後在域名詳細資料或 Cloudflare Dashboard 查看。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflare 尚未回傳名稱伺服器，請稍後在網域詳細資訊或 Cloudflare Dashboard 檢視。"
          }
        }
      }
    },
