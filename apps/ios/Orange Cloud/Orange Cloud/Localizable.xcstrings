    "移除已断开的连接记录；活跃的 cloudflared 会自动重连。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يزيل سجلات الاتصالات المنقطعة؛ وتُعيد نُسخ cloudflared النشطة الاتصال تلقائيًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entfernt Datensätze getrennter Verbindungen; aktive cloudflared-Instanzen verbinden sich automatisch neu."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Removes records of disconnected connections; active cloudflared instances reconnect automatically."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina los registros de conexiones desconectadas; las instancias activas de cloudflared se reconectan automáticamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprime les enregistrements des connexions déconnectées ; les instances cloudflared actives se reconnectent automatiquement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "切断された接続の記録を削除します。アクティブな cloudflared は自動的に再接続します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "끊긴 연결 기록을 제거합니다. 활성 cloudflared는 자동으로 다시 연결됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove os registros de conexões desconectadas; instâncias ativas do cloudflared se reconectam automaticamente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove os registos de ligações terminadas; as instâncias ativas do cloudflared voltam a ligar-se automaticamente."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kesilen bağlantıların kayıtlarını kaldırır; etkin cloudflared örnekleri otomatik olarak yeniden bağlanır."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "移除已中斷的連線記錄；活躍的 cloudflared 會自動重新連線。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "移除已中斷的連線記錄；活躍的 cloudflared 會自動重新連線。"
          }
        }
      }
    },
