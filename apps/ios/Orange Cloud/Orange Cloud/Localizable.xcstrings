    "子路径匹配开启后，「保留剩余路径」才生效。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يسري «الحفاظ على بقية المسار» فقط عند تفعيل مطابقة المسار الفرعي."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Restpfad beibehalten“ gilt nur, wenn der Subpfad-Abgleich aktiviert ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "“Preserve path suffix” only applies when subpath matching is on."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "«Conservar el resto de la ruta» solo se aplica cuando la coincidencia de subruta está activada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« Conserver le reste du chemin » ne s'applique que lorsque la correspondance de sous-chemin est activée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「残りのパスを保持」は、サブパスのマッチングが有効な場合にのみ適用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "‘나머지 경로 유지’는 하위 경로 일치가 켜져 있을 때만 적용됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "“Preservar o restante do caminho” só se aplica quando a correspondência de subcaminho está ativada."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "“Preservar o resto do caminho” só se aplica quando a correspondência de subcaminho está ativada."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "“Kalan yolu koru”, yalnızca alt yol eşleştirme açıkken geçerlidir."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "子路徑比對開啟後，「保留剩餘路徑」才生效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "子路徑比對開啟後，「保留剩餘路徑」才生效。"
          }
        }
      }
    },
    "字母、数字、下划线，且不以数字开头。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أحرف وأرقام وشرطات سفلية؛ ولا يبدأ برقم."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Buchstaben, Zahlen und Unterstriche; darf nicht mit einer Zahl beginnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Letters, numbers, and underscores; can’t start with a number."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Letras, números y guiones bajos; no puede empezar por un número."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lettres, chiffres et traits de soulignement ; ne peut pas commencer par un chiffre."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "英字・数字・アンダースコアを使用でき、数字で始めることはできません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "영문자, 숫자, 밑줄을 사용하며 숫자로 시작할 수 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Letras, números e sublinhados; não pode começar com número."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Letras, números e sublinhados; não pode começar por um número."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Harf, rakam ve alt çizgi; rakamla başlayamaz."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "字母、數字、底線，且不以數字開頭。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "字母、數字、底線，且不以數字開頭。"
          }
        }
      }
    },
