    "仅退出此账号并撤销其授权，其他已登录账号不受影响。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم تسجيل خروج هذا الحساب فقط وإلغاء تفويضه. لا تتأثر الحسابات الأخرى."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur dieses Konto wird abgemeldet und seine Autorisierung widerrufen. Andere Konten sind nicht betroffen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only this account is signed out and its authorization revoked. Other accounts are unaffected."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo se cierra esta cuenta y se revoca su autorización. Las demás cuentas no se ven afectadas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seul ce compte est déconnecté et son autorisation révoquée. Les autres comptes ne sont pas affectés."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアカウントのみログアウトし、認可を取り消します。他のアカウントには影響しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 계정만 로그아웃되고 인증이 취소됩니다. 다른 로그인된 계정은 영향을 받지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas esta conta é desconectada e sua autorização é revogada. As outras contas não são afetadas."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas esta conta termina sessão e a sua autorização é revogada. As outras contas não são afetadas."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yalnızca bu hesabın oturumu kapatılır ve yetkilendirmesi iptal edilir. Diğer hesaplar etkilenmez."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "僅登出此帳戶並撤銷其授權，其他已登入帳戶不受影響。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅登出此帳號並撤銷其授權，其他已登入帳號不受影響。"
          }
        }
      }
    },
    "仅限字母、数字、下划线（如 my_redirects），用于规则表达式引用。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الحروف والأرقام والشرطة السفلية فقط (مثل my_redirects)؛ تُستخدم للإشارة إلى القائمة في تعبيرات القواعد."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur Buchstaben, Ziffern und Unterstriche (z. B. my_redirects) – wird in Regelausdrücken zur Referenz auf die Liste verwendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Letters, numbers, and underscores only (e.g. my_redirects) — used to reference the list in rule expressions."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo letras, números y guiones bajos (p. ej. my_redirects); se usa para referenciar la lista en expresiones de reglas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lettres, chiffres et tirets bas uniquement (p. ex. my_redirects) — sert à référencer la liste dans les expressions de règles."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "英数字とアンダースコアのみ（例：my_redirects）。ルール式での参照に使われます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "문자, 숫자, 밑줄만 사용(예: my_redirects). 규칙 식에서 목록을 참조하는 데 사용됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas letras, números e sublinhados (ex. my_redirects); usado para referenciar a lista em expressões de regra."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas letras, números e sublinhados (ex. my_redirects); usado para referenciar a lista em expressões de regra."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yalnızca harf, rakam ve alt çizgi (örn. my_redirects); kural ifadelerinde listeye başvurmak için kullanılır."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "僅限字母、數字、底線（如 my_redirects），用於規則運算式引用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅限字母、數字、底線（如 my_redirects），用於規則運算式引用。"
          }
        }
      }
    },
