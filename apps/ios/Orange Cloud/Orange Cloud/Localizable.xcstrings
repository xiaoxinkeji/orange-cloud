    "开启后在 Zone 状态变化或 Workers 出错时收到提醒。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احصل على تنبيه عند تغيّر حالة نطاق أو حدوث أخطاء في Workers."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erhalte Benachrichtigungen, wenn sich der Status einer Domain ändert oder Workers Fehler haben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get alerted when a domain’s status changes or Workers hit errors."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Recibe alertas cuando cambie el estado de un dominio o los Workers tengan errores."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Soyez alerté lorsque l’état d’un domaine change ou que les Workers rencontrent des erreurs."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると、ドメインのステータス変化や Workers のエラー時に通知を受け取れます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "도메인 상태가 바뀌거나 Workers에 오류가 발생하면 알림을 받습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Receba alertas quando o status de um domínio mudar ou os Workers apresentarem erros."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Receba alertas quando o estado de um domínio mudar ou os Workers apresentarem erros."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir alan adının durumu değiştiğinde veya Workers hata aldığında uyarı alın."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後在域名狀態變化或 Workers 出錯時收到提醒。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後在網域狀態變化或 Workers 出錯時收到提醒。"
          }
        }
      }
    },
    "开启后该 Worker 可经 <脚本名>.<子域>.workers.dev 访问。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، يصبح الـ Worker متاحًا على <اسم النص>.<النطاق الفرعي>.workers.dev."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn aktiviert, ist der Worker unter <Skript>.<Subdomain>.workers.dev erreichbar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When enabled, the Worker is reachable at <script>.<subdomain>.workers.dev."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Al activarlo, el Worker es accesible en <script>.<subdominio>.workers.dev."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une fois activé, le Worker est accessible à <script>.<sous-domaine>.workers.dev."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効にすると、Worker は <スクリプト名>.<サブドメイン>.workers.dev でアクセスできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사용하면 Worker는 <스크립트>.<서브도메인>.workers.dev에서 접근할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, o Worker fica acessível em <script>.<subdomínio>.workers.dev."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, o Worker fica acessível em <script>.<subdomínio>.workers.dev."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Etkinleştirildiğinde Worker, <betik>.<alt alan adı>.workers.dev adresinden erişilebilir."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後該 Worker 可經 <指令碼名>.<子域>.workers.dev 存取。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後該 Worker 可經 <指令碼名>.<子網域>.workers.dev 存取。"
          }
        }
      }
    },
    "开启后，%@ 将临时绕过 Cloudflare 缓存，源站负载会上升；3 小时后自动关闭。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بعد التفعيل، سيتجاوز %@ مؤقتًا التخزين المؤقت لـ Cloudflare وسيرتفع حمل المصدر. يتوقف تلقائيًا بعد 3 ساعات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nach dem Aktivieren umgeht %@ vorübergehend den Cloudflare-Cache und die Origin-Last steigt. Wird nach 3 Stunden automatisch deaktiviert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Once enabled, %@ will temporarily bypass the Cloudflare cache and origin load will increase. Turns off automatically after 3 hours."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Tras activarlo, %@ omitirá temporalmente la caché de Cloudflare y la carga del origen aumentará. Se desactiva tras 3 horas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une fois activé, %@ contournera temporairement le cache Cloudflare et la charge de l’origine augmentera. Désactivé automatiquement après 3 heures."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効にすると、%@ は一時的に Cloudflare のキャッシュをバイパスし、オリジンの負荷が上がります。3 時間後に自動的にオフになります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜면 %@이(가) Cloudflare 캐시를 임시로 우회하여 원본 서버 부하가 증가합니다. 3시간 후 자동으로 꺼집니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Após ativar, %@ ignorará temporariamente o cache da Cloudflare e a carga do servidor de origem aumentará. Desativa automaticamente após 3 horas."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Após ativar, %@ ignorará temporariamente a cache da Cloudflare e a carga do servidor de origem aumentará. Desativa automaticamente após 3 horas."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Etkinleştirildiğinde %@ geçici olarak Cloudflare önbelleğini atlar ve kaynak yükü artar. 3 saat sonra otomatik olarak kapanır."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後，%@ 將暫時繞過 Cloudflare 緩存，源站負載會上升；3 小時後自動關閉。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後，%@ 將暫時繞過 Cloudflare 快取，源站負載會上升；3 小時後自動關閉。"
          }
        }
      }
    },
    "开启后，访问 %@ 的所有访客都会先看到约 5 秒的质询页，可能影响正常用户体验。适合正在遭受攻击时使用。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بعد التفعيل، سيرى كل زائر لـ %@ صفحة تحدٍّ لمدة 5 ثوانٍ تقريبًا أولًا، مما قد يؤثر على تجربة المستخدمين الشرعيين. استخدمه أثناء هجوم نشط."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nach dem Aktivieren sehen alle Besucher von %@ zuerst etwa 5 Sekunden lang eine Challenge-Seite, was die Erfahrung legitimer Nutzer beeinträchtigen kann. Verwende dies während eines aktiven Angriffs."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Once enabled, every visitor to %@ will first see a challenge page for about 5 seconds, which may affect the experience of legitimate users. Use this while under an active attack."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Tras activarlo, todos los visitantes de %@ verán primero una página de desafío de unos 5 segundos, lo que puede afectar a los usuarios legítimos. Úsalo durante un ataque activo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une fois activé, chaque visiteur de %@ verra d’abord une page de défi pendant environ 5 secondes, ce qui peut affecter l’expérience des utilisateurs légitimes. À utiliser pendant une attaque active."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効にすると、%@ へのすべての訪問者に約 5 秒のチャレンジページが表示され、通常のユーザー体験に影響する可能性があります。攻撃を受けている間の使用に適しています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜면 %@의 모든 방문자가 약 5초간 챌린지 페이지를 먼저 보게 되어 정상 사용자 경험에 영향을 줄 수 있습니다. 공격을 받고 있을 때 사용하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Após ativar, todos os visitantes de %@ verão primeiro uma página de desafio de cerca de 5 segundos, o que pode afetar usuários legítimos. Use durante um ataque ativo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Após ativar, todos os visitantes de %@ verão primeiro uma página de desafio de cerca de 5 segundos, o que pode afetar utilizadores legítimos. Use durante um ataque ativo."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Etkinleştirildiğinde %@ adresine gelen her ziyaretçi önce yaklaşık 5 saniye boyunca bir sınama sayfası görür; bu, gerçek kullanıcıların deneyimini etkileyebilir. Etkin bir saldırı sırasında kullanın."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後，訪問 %@ 的所有訪客都會先看到約 5 秒的質詢頁，可能影響正常用戶體驗。適合正在遭受攻擊時使用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後，造訪 %@ 的所有訪客都會先看到約 5 秒的質詢頁，可能影響正常使用者體驗。適合正在遭受攻擊時使用。"
          }
        }
      }
    },
    "开启后：登录身份经 iCloud 钥匙串在你的设备间同步（端到端加密），账单日与套餐预设等偏好经 iCloud 同步。关闭将把登录信息从 iCloud 移除，仅保留本机。": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، تتزامن هويات تسجيل الدخول بين أجهزتك عبر سلسلة مفاتيح iCloud (مشفّرة من طرف إلى طرف)، وتتزامن التفضيلات مثل يوم الفوترة وإعدادات الخطة عبر iCloud. الإيقاف يزيل بيانات تسجيل الدخول من iCloud ويبقيها على هذا الجهاز فقط."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn aktiviert, werden Anmeldeidentitäten über den iCloud-Schlüsselbund zwischen deinen Geräten synchronisiert (Ende-zu-Ende-verschlüsselt), und Einstellungen wie Abrechnungstag und Tarifvorgaben werden über iCloud synchronisiert. Beim Deaktivieren werden die Anmeldedaten aus iCloud entfernt und nur auf diesem Gerät behalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, sign-in identities sync across your devices via iCloud Keychain (end-to-end encrypted), and preferences like billing day and plan presets sync via iCloud. Turning it off removes sign-in data from iCloud and keeps it on this device only."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, las identidades de inicio de sesión se sincronizan entre tus dispositivos mediante el Llavero de iCloud (cifrado de extremo a extremo), y preferencias como el día de facturación y los planes se sincronizan vía iCloud. Al desactivarlo se eliminan los datos de inicio de sesión de iCloud y se conservan solo en este dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsqu’elle est activée, les identités de connexion sont synchronisées entre vos appareils via le trousseau iCloud (chiffrement de bout en bout), et les préférences telles que le jour de facturation et les forfaits prédéfinis sont synchronisées via iCloud. La désactiver supprime les données de connexion d’iCloud et les conserve uniquement sur cet appareil."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると、ログイン情報は iCloud キーチェーン経由でデバイス間に同期され（エンドツーエンド暗号化）、請求日やプラン設定などの環境設定も iCloud で同期されます。オフにすると、ログイン情報は iCloud から削除され、このデバイスのみに保持されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜면 로그인 ID가 iCloud 키체인을 통해 기기 간에 동기화되고(종단 간 암호화), 청구일 및 요금제 사전 설정 같은 환경설정이 iCloud로 동기화됩니다. 끄면 로그인 정보가 iCloud에서 제거되고 이 기기에만 유지됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, as identidades de login são sincronizadas entre seus dispositivos pelo Chaveiro do iCloud (criptografia de ponta a ponta), e preferências como dia de cobrança e planos são sincronizadas via iCloud. Desativar remove os dados de login do iCloud e os mantém apenas neste dispositivo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, as identidades de início de sessão são sincronizadas entre os seus dispositivos pelo Porta-chaves do iCloud (encriptação ponta a ponta), e preferências como dia de faturação e planos são sincronizadas via iCloud. Desativar remove os dados de início de sessão do iCloud e mantém-nos apenas neste dispositivo."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Etkinleştirildiğinde oturum açma kimlikleri iCloud Anahtar Zinciri aracılığıyla cihazlarınız arasında eşitlenir (uçtan uca şifreli) ve faturalandırma günü ile plan ön ayarları gibi tercihler iCloud üzerinden eşitlenir. Kapatmak, oturum açma verilerini iCloud’dan kaldırır ve yalnızca bu cihazda tutar."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後：登入身分經 iCloud 鑰匙串在你的裝置間同步（端對端加密），帳單日與計劃預設等偏好經 iCloud 同步。關閉將把登入資料從 iCloud 移除，僅保留本機。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後：登入身分經 iCloud 鑰匙圈在你的裝置間同步（端對端加密），帳單日與方案預設等偏好經 iCloud 同步。關閉將把登入資訊從 iCloud 移除，僅保留本機。"
          }
        }
      }
    },
