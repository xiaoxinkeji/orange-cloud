    "删除项目会移除所有部署，且不可撤销。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حذف المشروع يزيل جميع عمليات النشر ولا يمكن التراجع عنه."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Löschen des Projekts entfernt alle Deployments und kann nicht rückgängig gemacht werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deleting the project removes all deployments and cannot be undone."
          }
        },
        "es-MX": {
