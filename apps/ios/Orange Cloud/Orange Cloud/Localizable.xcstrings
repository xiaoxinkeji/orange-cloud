          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe oben rechts auf +, um einen Tunnel zu erstellen, oder erstelle einen mit cloudflared und sieh ihn hier"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap + in the top right to create a tunnel, or create one with cloudflared and view it here"
          }
