        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "La autorización actual no tiene el permiso necesario para esta acción (%@). Toca «Reautorizar» para agregarlo, sin cerrar sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'autorisation actuelle ne dispose pas de l'autorisation requise pour cette action (%@). Touchez « Réautoriser » pour l'ajouter, sans déconnexion."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在の認可には、この操作に必要な権限（%@）が含まれていません。「再認可」をタップして追加できます（ログアウト不要）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 권한에는 이 작업에 필요한 권한(%@)이 없습니다. ‘재인증’을 눌러 추가하세요(로그아웃 불필요)."
