            "value": "Saisissez un domaine racine que vous possédez déjà (p. ex. example.com) — sans www ni https://."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "取得済みのルートドメイン（例：example.com）を入力します。www や https:// は不要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이미 보유한 루트 도메인(예: example.com)을 입력하세요. www나 https://는 필요 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Insira um domínio raiz que você já tem (ex.: example.com), sem www nem https://."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Introduza um domínio raiz que já possui (ex.: example.com), sem www nem https://."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaten sahip olduğunuz bir kök alan adı girin (ör. example.com) — www veya https:// gerekmez."
