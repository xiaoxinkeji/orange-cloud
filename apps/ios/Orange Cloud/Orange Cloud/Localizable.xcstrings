    "按 URL 自定义边缘/浏览器缓存 TTL、绕过缓存等缓存规则属于 Orange Cloud Pro。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قواعد التخزين المؤقت — تخصيص مدة بقاء التخزين على الحافة/المتصفح لكل URL وتجاوز التخزين وغير ذلك — جزء من Orange Cloud Pro."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Cache-Regeln – Edge-/Browser-Cache-TTLs pro URL anpassen, Cache umgehen und mehr – sind Teil von Orange Cloud Pro."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cache rules — customizing edge/browser cache TTLs per URL, bypassing cache, and more — are part of Orange Cloud Pro."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Las reglas de caché —personalizar el TTL de caché de borde/navegador por URL, omitir la caché y más— son parte de Orange Cloud Pro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les règles de cache — personnaliser les TTL de cache edge/navigateur par URL, contourner le cache, etc. — font partie d'Orange Cloud Pro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "URL ごとのエッジ／ブラウザーキャッシュ TTL のカスタマイズやキャッシュのバイパスなどのキャッシュルールは Orange Cloud Pro の機能です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "URL별 엣지/브라우저 캐시 TTL 설정, 캐시 우회 등 캐시 규칙은 Orange Cloud Pro 기능입니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As regras de cache — personalizar TTLs de cache de borda/navegador por URL, ignorar o cache e mais — fazem parte do Orange Cloud Pro."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "As regras de cache — personalizar TTLs de cache de extremidade/navegador por URL, ignorar o cache e mais — fazem parte do Orange Cloud Pro."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Önbellek kuralları — URL bazında uç/tarayıcı önbellek TTL'lerini özelleştirme, önbelleği atlama ve daha fazlası — Orange Cloud Pro kapsamındadır."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "按 URL 自訂邊緣／瀏覽器緩存 TTL、繞過緩存等緩存規則屬於 Orange Cloud Pro。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "依 URL 自訂邊緣／瀏覽器快取 TTL、略過快取等快取規則屬於 Orange Cloud Pro。"
          }
        }
      }
    },
    "按 URL 覆盖边缘/浏览器缓存时长或绕过缓存": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تجاوز مدة التخزين المؤقت على الحافة/المتصفح لكل URL أو تجاوز التخزين المؤقت"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Edge-/Browser-Cache-TTLs pro URL überschreiben oder Cache umgehen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Override edge/browser cache TTLs per URL or bypass cache"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Anula el TTL de caché de borde/navegador por URL u omite la caché"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Remplacer les TTL de cache edge/navigateur par URL ou contourner le cache"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "URL ごとにエッジ／ブラウザーキャッシュ時間を上書き、またはキャッシュをバイパス"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "URL별 엣지/브라우저 캐시 시간 재정의 또는 캐시 우회"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Substitua os TTLs de cache de borda/navegador por URL ou ignore o cache"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Substitua os TTLs de cache de extremidade/navegador por URL ou ignore o cache"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "URL bazında uç/tarayıcı önbellek süresini geçersiz kılın veya önbelleği atlayın"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "按 URL 覆寫邊緣／瀏覽器緩存時間或繞過緩存"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "依 URL 覆寫邊緣／瀏覽器快取時間或略過快取"
          }
        }
      }
    },
    "按上方顺序作为主用池，前面的不可用时依次故障转移。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُستخدم كمجمّعات أساسية بالترتيب أعلاه؛ وإذا تعذّر توفّر مجمّع سابق، يتحوّل المرور إلى التالي."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Werden in der obigen Reihenfolge als primäre Pools verwendet; ist ein vorheriger nicht verfügbar, erfolgt ein Failover zum nächsten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Used as primary pools in the order above; if an earlier one is unavailable, traffic fails over to the next."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Se usan como grupos principales en el orden anterior; si uno previo no está disponible, el tráfico conmuta al siguiente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisés comme pools principaux dans l'ordre ci-dessus ; si l'un précédent est indisponible, le trafic bascule vers le suivant."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "上記の順序でプライマリプールとして使用されます。前のプールが利用できない場合は、順に次へフェイルオーバーします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "위 순서대로 기본 풀로 사용되며, 앞의 풀을 사용할 수 없으면 차례로 다음 풀로 장애 조치됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Usados como pools principais na ordem acima; se um anterior ficar indisponível, o tráfego faz failover para o próximo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Usados como pools principais pela ordem acima; se um anterior ficar indisponível, o tráfego faz failover para o seguinte."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yukarıdaki sırayla birincil havuzlar olarak kullanılır; öncekilerden biri kullanılamazsa trafik sıradakine yük devreder."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "依上方順序作為主要池，前面的不可用時依序故障轉移。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "依上方順序作為主要池，前面的不可用時依序故障轉移。"
          }
        }
      }
    },
