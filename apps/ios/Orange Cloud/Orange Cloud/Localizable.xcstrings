    "每行一个完整 URL，单次最多 %lld 个。例如 https://%@/style.css": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عنوان URL كامل واحد في كل سطر، حتى %lld في المرة الواحدة. على سبيل المثال، https://%@/style.css"
          }
        },
        "de": {
          "stringUnit": {
