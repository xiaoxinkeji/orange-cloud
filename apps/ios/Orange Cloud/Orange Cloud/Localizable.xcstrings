    "决定哪些请求按查询字符串缓存": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتحكم في الطلبات التي تُخزَّن مؤقتًا حسب سلسلة الاستعلام"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Steuert, welche Anfragen anhand der Query-Zeichenfolge zwischengespeichert werden"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Controls which requests are cached by query string"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Controla qué solicitudes se almacenan en caché según la cadena de consulta"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
