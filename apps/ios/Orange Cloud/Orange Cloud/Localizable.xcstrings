    "列表展示的是本地缓存，下拉可从 Cloudflare 拉取最新数据": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعرض القائمة التخزين المؤقت المحلي. اسحب للأسفل لجلب أحدث البيانات من Cloudflare."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Liste zeigt den lokalen Cache. Zieh nach unten, um die neuesten Daten von Cloudflare zu laden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The list shows the local cache. Pull down to fetch the latest from Cloudflare."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "La lista muestra la caché local. Desliza para obtener lo más reciente de Cloudflare."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La liste affiche le cache local. Tirez vers le bas pour récupérer les données les plus récentes de Cloudflare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リストはローカルキャッシュを表示しています。下に引くと Cloudflare から最新を取得します"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "목록은 로컬 캐시를 표시합니다. 당겨서 Cloudflare에서 최신 데이터를 가져오세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A lista mostra o cache local. Puxe para buscar os dados mais recentes da Cloudflare."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A lista mostra a cache local. Puxe para obter os dados mais recentes da Cloudflare."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Liste yerel önbelleği gösterir. En son verileri Cloudflare’dan almak için aşağı çekin."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "列表顯示的是本機緩存，下拉可從 Cloudflare 取得最新數據"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "列表顯示的是本機快取，下拉可從 Cloudflare 取得最新資料"
          }
        }
      }
    },
