    "设备端模型暂时不可用，请稍后再试。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "النموذج على الجهاز غير متاح مؤقتًا. يرجى المحاولة لاحقًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das geräteinterne Modell ist vorübergehend nicht verfügbar. Bitte versuche es später erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The on-device model is temporarily unavailable. Please try again later."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "El modelo en el dispositivo no está disponible temporalmente. Inténtalo de nuevo más tarde."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le modèle sur l’appareil est temporairement indisponible. Veuillez réessayer plus tard."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイス上のモデルは一時的に利用できません。しばらくしてからお試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기기 내 모델을 일시적으로 사용할 수 없습니다. 잠시 후 다시 시도해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O modelo no dispositivo está temporariamente indisponível. Tente novamente mais tarde."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O modelo no dispositivo está temporariamente indisponível. Tente novamente mais tarde."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cihaz üzerindeki model geçici olarak kullanılamıyor. Lütfen daha sonra tekrar deneyin."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "裝置端模型暫時無法使用，請稍後再試。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "裝置端模型暫時無法使用，請稍後再試。"
          }
        }
      }
    },
