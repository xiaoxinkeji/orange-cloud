    },
    "在 %@ 上，按访客 IP 在时间窗内限制请求次数。规则自上而下匹配。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "على %@، تُحدّد عدد الطلبات حسب IP الزائر ضمن نافذة زمنية. تُطابَق القواعد من الأعلى إلى الأسفل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Begrenzt auf %@ die Anzahl der Anfragen pro Besucher-IP innerhalb eines Zeitfensters. Regeln werden von oben nach unten ausgewertet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On %@, limit requests per visitor IP within a time window. Rules are matched top to bottom."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "En %@, limita las solicitudes por IP de visitante dentro de una ventana de tiempo. Las reglas se evalúan de arriba abajo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sur %@, limite les requêtes par IP de visiteur dans une fenêtre temporelle. Les règles sont évaluées de haut en bas."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ で、時間枠内の訪問者 IP ごとのリクエスト数を制限します。ルールは上から順に照合されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@에서 시간 범위 내 방문자 IP별 요청 수를 제한합니다. 규칙은 위에서 아래로 매칭됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Em %@, limite as solicitações por IP de visitante dentro de uma janela de tempo. As regras são avaliadas de cima para baixo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Em %@, limite os pedidos por IP de visitante dentro de uma janela de tempo. As regras são avaliadas de cima para baixo."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ üzerinde, bir zaman aralığında ziyaretçi IP’si başına istekleri sınırlayın. Kurallar yukarıdan aşağıya eşleşir."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "在 %@ 上，依訪客 IP 在時間範圍內限制請求次數。規則由上而下比對。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 %@ 上，依訪客 IP 在時間範圍內限制請求次數。規則由上而下比對。"
          }
        }
      }
    },
    "在 App 里把已注册的域名加入账号，并拿到要去注册商处配置的名称服务器。": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضِف نطاقًا تملكه بالفعل إلى حسابك واحصل على خوادم الأسماء لضبطها لدى مُسجِّل النطاق."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge eine Domain, die dir bereits gehört, deinem Konto hinzu und erhalte die Nameserver, die du bei deinem Registrar einträgst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a domain you already own to your account and get the name servers to set at your registrar."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Agrega a tu cuenta un dominio que ya tengas y obtén los servidores de nombres para configurarlos en tu registrador."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez à votre compte un domaine que vous possédez déjà et obtenez les serveurs de noms à configurer chez votre registraire."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "取得済みのドメインをアカウントに追加し、レジストラで設定するネームサーバを取得します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이미 보유한 도메인을 계정에 추가하고 등록 대행자에 설정할 네임서버를 받으세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione à sua conta um domínio que você já tem e obtenha os servidores de nomes para configurar no seu registrador."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione à sua conta um domínio que já possui e obtenha os servidores de nomes para configurar no seu registador."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaten sahip olduğunuz bir alan adını hesabınıza ekleyin ve kayıt kuruluşunuzda ayarlamanız gereken ad sunucularını alın."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "將你已註冊的域名加入帳戶，並取得要在註冊商處設定的名稱伺服器。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將你已註冊的網域加入帳號，並取得要在註冊商處設定的名稱伺服器。"
