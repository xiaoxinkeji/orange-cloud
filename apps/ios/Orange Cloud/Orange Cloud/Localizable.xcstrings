    "例如：拦截来自中国大陆、访问 /admin 的请求": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مثال: حظر الطلبات القادمة من البر الرئيسي للصين والتي تصل إلى /admin"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "z. B. Anfragen aus dem chinesischen Festland blockieren, die auf /admin zugreifen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "e.g. Block requests from China that hit /admin"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "p. ej., bloquear solicitudes desde China que accedan a /admin"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "p. ex. bloquer les requêtes de Chine continentale qui accèdent à /admin"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "例：中国本土から /admin にアクセスするリクエストをブロック"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "예: 중국 본토에서 /admin에 접근하는 요청 차단"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "ex.: bloquear solicitações da China que acessem /admin"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "ex.: bloquear pedidos da China que acedam a /admin"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "ör. /admin adresine erişen, Çin anakarasından gelen istekleri engelle"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "例如：攔截來自中國大陸、存取 /admin 的請求"
          }
