    },
    "留空表示不改写该部分；按静态值重写。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اتركه فارغًا للإبقاء على هذا الجزء دون تغيير؛ يُعاد كتابته بقيمة ثابتة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Leer lassen, um diesen Teil unverändert zu lassen; wird auf einen statischen Wert umgeschrieben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Leave blank to keep that part unchanged; rewrites to a static value."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Déjalo en blanco para no cambiar esa parte; reescribe a un valor estático."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Laissez vide pour conserver cette partie inchangée ; réécrit vers une valeur statique."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "空欄にするとその部分は変更しません。静的な値に書き換えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "비워 두면 해당 부분은 변경되지 않습니다. 정적 값으로 다시 씁니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Deixe em branco para não alterar essa parte; reescreve para um valor estático."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Deixe em branco para não alterar essa parte; reescreve para um valor estático."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu kısmı değiştirmeden bırakmak için boş bırakın; statik bir değere yeniden yazılır."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "留空表示不改寫該部分；按靜態值重寫。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "留空表示不改寫該部分；按靜態值重寫。"
          }
        }
      }
    },
