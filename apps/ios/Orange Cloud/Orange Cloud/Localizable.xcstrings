    "免费版可登录一个 Cloudflare 账号；Pro 可添加多个账号并快速切换。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تتيح النسخة المجانية تسجيل الدخول إلى حساب Cloudflare واحد. أما Pro فيضيف حسابات متعددة مع تبديل سريع."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die kostenlose Version meldet sich bei einem Cloudflare-Konto an. Pro ermöglicht mehrere Konten mit schnellem Wechsel."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The free tier signs in to one Cloudflare account. Pro adds multiple accounts with quick switching."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "La versión gratuita inicia sesión en una cuenta de Cloudflare. Pro agrega varias cuentas con cambio rápido."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La version gratuite se connecte à un compte Cloudflare. Pro permet plusieurs comptes avec changement rapide."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無料版では 1 つの Cloudflare アカウントにログインできます。Pro なら複数アカウントを追加してすばやく切り替えられます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "무료 버전은 Cloudflare 계정 하나에 로그인합니다. Pro는 여러 계정을 추가하고 빠르게 전환할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A versão gratuita entra em uma conta da Cloudflare. O Pro adiciona várias contas com troca rápida."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A versão gratuita inicia sessão numa conta da Cloudflare. O Pro adiciona várias contas com troca rápida."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ücretsiz sürüm tek bir Cloudflare hesabında oturum açar. Pro, hızlı geçişle birden çok hesap ekler."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "免費版可登入一個 Cloudflare 帳戶；Pro 可新增多個帳戶並快速切換。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "免費版可登入一個 Cloudflare 帳號；Pro 可新增多個帳號並快速切換。"
          }
        }
      }
    },
    "全程加密并校验源站证书，最安全。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يشفّر من طرف إلى طرف ويتحقق من شهادة المصدر — الخيار الأكثر أمانًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verschlüsselt Ende-zu-Ende und validiert das Origin-Zertifikat – die sicherste Option."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Encrypts end to end and validates the origin certificate — the most secure option."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Cifra de extremo a extremo y valida el certificado de origen: la opción más segura."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chiffre de bout en bout et valide le certificat de l’origine — l’option la plus sûre."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エンドツーエンドで暗号化し、オリジン証明書も検証します。最も安全です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "종단 간 암호화하고 원본 인증서를 확인합니다. 가장 안전합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Criptografa de ponta a ponta e valida o certificado de origem — a opção mais segura."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Encripta de ponta a ponta e valida o certificado de origem — a opção mais segura."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uçtan uca şifreler ve kaynak sertifikasını doğrular — en güvenli seçenek."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "全程加密並驗證源站證書，最安全。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "全程加密並驗證源站憑證，最安全。"
          }
        }
      }
    },
    "全程加密，但不校验源站证书。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يشفّر من طرف إلى طرف، لكنه لا يتحقق من شهادة المصدر."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verschlüsselt Ende-zu-Ende, validiert aber das Origin-Zertifikat nicht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Encrypts end to end, but does not validate the origin certificate."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Cifra de extremo a extremo, pero no valida el certificado de origen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chiffre de bout en bout, mais ne valide pas le certificat de l’origine."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エンドツーエンドで暗号化しますが、オリジン証明書は検証しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "종단 간 암호화하지만 원본 인증서를 확인하지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Criptografa de ponta a ponta, mas não valida o certificado de origem."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Encripta de ponta a ponta, mas não valida o certificado de origem."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uçtan uca şifreler, ancak kaynak sertifikasını doğrulamaz."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "全程加密，但不驗證源站證書。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "全程加密，但不驗證源站憑證。"
          }
        }
