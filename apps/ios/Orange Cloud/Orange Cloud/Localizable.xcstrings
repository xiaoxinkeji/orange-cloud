    "URL 模式，可用 * 通配，如 example.com/*。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نمط عنوان URL؛ تعمل * كحرف بدل، مثل example.com/*."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein URL-Muster; * dient als Platzhalter, z. B. example.com/*."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A URL pattern; * works as a wildcard, e.g. example.com/*."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Un patrón de URL; * funciona como comodín, p. ej. example.com/*."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un modèle d’URL ; * sert de caractère générique, p. ex. example.com/*."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "URL パターンです。* をワイルドカードとして使えます（例：example.com/*）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "URL 패턴이며 *를 와일드카드로 사용할 수 있습니다(예: example.com/*)."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um padrão de URL; * funciona como curinga, ex.: example.com/*."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Um padrão de URL; * funciona como carácter universal, ex.: example.com/*."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir URL kalıbı; * joker olarak çalışır, ör. example.com/*."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "URL 模式，可用 * 萬用字元，如 example.com/*。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "URL 模式，可用 * 萬用字元，如 example.com/*。"
          }
