        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A autorização atual não tem a permissão necessária para esta ação (%@). Toque em “Reautorizar” para adicionar, sem sair da conta."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
