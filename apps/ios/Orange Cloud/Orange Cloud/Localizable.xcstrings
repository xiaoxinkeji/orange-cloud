    "查看隧道与连接状态；读写可新建隧道、配置公共主机名路由": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عرض الأنفاق وحالة الاتصال؛ تتيح القراءة/الكتابة إنشاء الأنفاق وضبط توجيه أسماء المضيفين العامة"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tunnel und Verbindungsstatus anzeigen; mit Lese-/Schreibzugriff kannst du Tunnel erstellen und das Routing öffentlicher Hostnamen konfigurieren"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "View tunnels and connection status; read/write lets you create tunnels and configure public hostname routing"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Consulta los túneles y el estado de conexión; con lectura/escritura puedes crear túneles y configurar el enrutamiento por nombre de host público"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Afficher les tunnels et l’état des connexions ; le lecture/écriture permet de créer des tunnels et de configurer le routage des noms d’hôte publics"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トンネルと接続状態を表示。読み取り/書き込みでトンネルの作成やパブリックホスト名ルーティングの設定ができます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "터널과 연결 상태 보기. 읽기/쓰기로 터널 생성과 공개 호스트 이름 라우팅을 구성할 수 있습니다"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Veja os túneis e o status da conexão; com leitura/escrita você pode criar túneis e configurar o roteamento por nome de host público"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Veja os túneis e o estado da ligação; com leitura/escrita pode criar túneis e configurar o encaminhamento por nome de anfitrião público"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tünelleri ve bağlantı durumunu görüntüleyin; okuma/yazma, tünel oluşturmanıza ve genel ana makine adı yönlendirmesini yapılandırmanıza olanak tanır"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "查看隧道與連線狀態；讀寫可建立隧道、設定公開主機名稱路由"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "檢視通道與連線狀態；讀寫可建立通道、設定公開主機名稱路由"
          }
        }
      }
    },
