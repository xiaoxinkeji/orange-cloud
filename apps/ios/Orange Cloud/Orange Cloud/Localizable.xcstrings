    },
    "每个账号独立登录授权。点击账号查看权限与退出登录。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يسجّل كل حساب الدخول بشكل مستقل. انقر على حساب لعرض الأذونات أو تسجيل الخروج."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jedes Konto meldet sich separat an. Tippe auf ein Konto, um Berechtigungen anzuzeigen oder dich abzumelden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Each account signs in separately. Tap an account to view permissions or sign out."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada cuenta inicia sesión por separado. Toca una cuenta para ver sus permisos o cerrar sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaque compte se connecte séparément. Touchez un compte pour voir les permissions ou vous déconnecter."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウントごとに個別にログインします。アカウントをタップすると権限の確認やログアウトができます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "각 계정은 개별적으로 로그인합니다. 계정을 눌러 권한을 보거나 로그아웃하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada conta entra separadamente. Toque em uma conta para ver as permissões ou sair."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada conta inicia sessão separadamente. Toque numa conta para ver as permissões ou terminar sessão."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her hesap ayrı oturum açar. İzinleri görüntülemek veya oturumu kapatmak için bir hesaba dokunun."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "每個帳戶獨立登入授權。點按帳戶可查看權限與登出。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "每個帳號獨立登入授權。點按帳號可檢視權限與登出。"
          }
        }
      }
    },
