    "增删条目为 Cloudflare 异步操作，提交后稍候即生效。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إضافة العناصر وحذفها عملية غير متزامنة في Cloudflare، وتسري بعد الإرسال بقليل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Hinzufügen und Entfernen von Einträgen ist ein asynchroner Cloudflare-Vorgang – er wird kurz nach dem Absenden wirksam."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adding and removing entries is an asynchronous Cloudflare operation — it takes effect shortly after you submit."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Agregar y quitar entradas es una operación asíncrona de Cloudflare; surte efecto poco después de enviarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'ajout et la suppression d'entrées sont une opération asynchrone de Cloudflare ; cela prend effet peu après l'envoi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "項目の追加・削除は Cloudflare の非同期操作です。送信後、まもなく反映されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "항목 추가·삭제는 Cloudflare의 비동기 작업으로, 제출 후 잠시 뒤에 적용됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicionar e remover entradas é uma operação assíncrona da Cloudflare; entra em vigor pouco depois do envio."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicionar e remover entradas é uma operação assíncrona da Cloudflare; entra em vigor pouco depois do envio."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Giriş ekleme ve kaldırma, Cloudflare'in eşzamansız bir işlemidir; göndermenizden kısa süre sonra geçerli olur."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "新增與刪除項目為 Cloudflare 非同步操作，送出後稍候即生效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "新增與刪除項目為 Cloudflare 非同步操作，送出後稍候即生效。"
