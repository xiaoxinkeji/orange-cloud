    "删除原有名称服务器，替换为上方两个 Cloudflare 地址。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احذف خوادم الأسماء الحالية واستبدلها بعنواني Cloudflare أعلاه."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entferne die bestehenden Nameserver und ersetze sie durch die beiden Cloudflare-Adressen oben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove the existing name servers and replace them with the two Cloudflare addresses above."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina los servidores de nombres actuales y reemplázalos por las dos direcciones de Cloudflare de arriba."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimez les serveurs de noms existants et remplacez-les par les deux adresses Cloudflare ci-dessus."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "既存のネームサーバを削除し、上の 2 つの Cloudflare アドレスに置き換えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기존 네임서버를 삭제하고 위의 Cloudflare 주소 두 개로 교체하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Remova os servidores de nomes atuais e substitua-os pelos dois endereços da Cloudflare acima."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Remova os servidores de nomes atuais e substitua-os pelos dois endereços da Cloudflare acima."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mevcut ad sunucularını kaldırın ve yukarıdaki iki Cloudflare adresiyle değiştirin."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "刪除原有名稱伺服器，替換為上方兩個 Cloudflare 位址。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "刪除原有名稱伺服器，替換為上方兩個 Cloudflare 位址。"
          }
        }
      }
    },
    "删除后不可恢复；不能删除当前生效的部署。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الحذف نهائي. لا يمكن حذف النشر الفعّال حاليًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Löschen ist endgültig. Das aktuell aktive Deployment kann nicht gelöscht werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deletion is permanent. The currently live deployment cannot be deleted."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "La eliminación es permanente. No se puede eliminar el despliegue activo actual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La suppression est définitive. Le déploiement actuellement en ligne ne peut pas être supprimé."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除すると元に戻せません。現在稼働中のデプロイは削除できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "삭제하면 복구할 수 없습니다. 현재 활성 배포는 삭제할 수 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A exclusão é permanente. A implantação ativa no momento não pode ser excluída."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A eliminação é permanente. A implementação atualmente ativa não pode ser eliminada."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Silme işlemi kalıcıdır. Şu anda yayında olan dağıtım silinemez."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "刪除後無法復原；無法刪除目前生效的部署。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "刪除後無法復原；無法刪除目前生效的部署。"
          }
        }
      }
    },
    "删除后该主机名将不再经负载均衡分发，立即影响线上流量。不可撤销。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بعد الحذف، لن يُقدَّم اسم المضيف هذا عبر موازنة التحميل، مما يؤثر على حركة المرور المباشرة فورًا. لا يمكن التراجع."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nach dem Löschen wird dieser Hostname nicht mehr über Load Balancing ausgeliefert – das wirkt sich sofort auf den Live-Traffic aus. Nicht widerrufbar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After deletion, this hostname will no longer be served via load balancing — affecting live traffic immediately. This cannot be undone."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Tras eliminarlo, este nombre de host dejará de distribuirse mediante el balanceo de carga, afectando de inmediato al tráfico en producción. No se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Après suppression, ce nom d'hôte ne sera plus servi via la répartition de charge, ce qui affecte immédiatement le trafic en production. Action irréversible."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除すると、このホスト名はロードバランシング経由で配信されなくなり、本番トラフィックに即時影響します。元に戻せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "삭제하면 이 호스트 이름은 더 이상 부하 분산으로 제공되지 않아 실시간 트래픽에 즉시 영향을 줍니다. 되돌릴 수 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Após a exclusão, este nome de host deixará de ser servido por balanceamento de carga, afetando o tráfego em produção imediatamente. Não pode ser desfeito."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Após a eliminação, este nome de anfitrião deixará de ser servido por balanceamento de carga, afetando o tráfego em produção de imediato. Não pode ser anulado."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Silindikten sonra bu ana bilgisayar adı artık yük dengeleme ile sunulmayacak ve canlı trafiği hemen etkileyecektir. Geri alınamaz."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "刪除後該主機名稱將不再經負載平衡分配，立即影響線上流量。無法復原。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "刪除後該主機名稱將不再經負載平衡分配，立即影響線上流量。無法復原。"
          }
        }
      }
    },
