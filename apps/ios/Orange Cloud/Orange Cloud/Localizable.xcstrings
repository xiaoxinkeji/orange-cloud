    "在目标机器上安装 cloudflared，并以管理员身份运行下面的命令，隧道即可连接。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ثبّت cloudflared على الجهاز المستهدف وشغّل الأمر أدناه كمسؤول لتوصيل النفق."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Installiere cloudflared auf dem Zielcomputer und führe den folgenden Befehl als Administrator aus, um den Tunnel zu verbinden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Install cloudflared on the target machine and run the command below as an administrator to connect the tunnel."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Instala cloudflared en la máquina de destino y ejecuta el siguiente comando como administrador para conectar el túnel."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Installez cloudflared sur la machine cible et exécutez la commande ci-dessous en tant qu’administrateur pour connecter le tunnel."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "対象のマシンに cloudflared をインストールし、下のコマンドを管理者として実行するとトンネルが接続されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "대상 컴퓨터에 cloudflared를 설치하고 아래 명령을 관리자 권한으로 실행하면 터널이 연결됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Instale o cloudflared na máquina de destino e execute o comando abaixo como administrador para conectar o túnel."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Instale o cloudflared na máquina de destino e execute o comando abaixo como administrador para ligar o túnel."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hedef makineye cloudflared’i kurun ve tüneli bağlamak için aşağıdaki komutu yönetici olarak çalıştırın."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "在目標機器上安裝 cloudflared，並以管理員身分執行下面的指令，隧道即可連線。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在目標機器上安裝 cloudflared，並以管理員身分執行下面的指令，通道即可連線。"
          }
        }
      }
    },
