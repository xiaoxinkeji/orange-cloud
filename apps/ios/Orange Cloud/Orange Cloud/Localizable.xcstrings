          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kullanım yüklenemedi. Tekrar denemek için yenileyin."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "用量載入失敗，下拉重新整理重試。"
