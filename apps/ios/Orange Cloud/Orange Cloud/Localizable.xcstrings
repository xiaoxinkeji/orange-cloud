    "未找到 %@ 所属域名，请手动添加代理 CNAME，目标 %@": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر العثور على نطاق %1$@. أضِف يدويًا سجل CNAME عبر الوكيل، الهدف %2$@"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Domain für %1$@ wurde nicht gefunden. Füge manuell einen proxied CNAME hinzu, Ziel %2$@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t find the domain for %1$@. Add a proxied CNAME manually, target %2$@"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "No se encontró el dominio de %1$@. Agrega manualmente un CNAME con proxy, destino %2$@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Domaine introuvable pour %1$@. Ajoutez manuellement un CNAME proxifié, cible %2$@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ の所属ドメインが見つかりません。プロキシ CNAME を手動で追加してください。ターゲットは %2$@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@의 도메인을 찾을 수 없습니다. 프록시 CNAME을 수동으로 추가하세요. 대상은 %2$@"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível encontrar o domínio de %1$@. Adicione um CNAME com proxy manualmente, destino %2$@"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível encontrar o domínio de %1$@. Adicione um CNAME com proxy manualmente, destino %2$@"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ için alan adı bulunamadı. Hedefi %2$@ olan proxy’li bir CNAME’i el ile ekleyin"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "找不到 %1$@ 所屬域名，請手動新增代理 CNAME，目標 %2$@"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "找不到 %1$@ 所屬網域，請手動新增代理 CNAME，目標 %2$@"
          }
        }
      }
    },
