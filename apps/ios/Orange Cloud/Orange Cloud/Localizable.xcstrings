          }
        }
      }
    },
    "将清空 %@ 在 Cloudflare 边缘的所有缓存，回源流量会短暂上升。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيؤدي هذا إلى مسح كل التخزين المؤقت لـ %@ على حافة Cloudflare. قد ترتفع حركة المرور إلى المصدر مؤقتًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch wird der gesamte Cache von %@ am Cloudflare-Edge geleert. Der Origin-Traffic kann kurzzeitig ansteigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This clears all of %@’s cache on Cloudflare’s edge. Origin traffic may briefly increase."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto borra toda la caché de %@ en el borde de Cloudflare. El tráfico al origen puede aumentar brevemente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela vide tout le cache de %@ à la périphérie de Cloudflare. Le trafic vers l’origine peut augmenter brièvement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ の Cloudflare エッジ上のキャッシュをすべて削除します。オリジンへのトラフィックが一時的に増える可能性があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflare 엣지에 있는 %@의 모든 캐시를 비웁니다. 원본 트래픽이 잠시 증가할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso limpa todo o cache de %@ na borda da Cloudflare. O tráfego de origem pode aumentar brevemente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto limpa toda a cache de %@ na periferia da Cloudflare. O tráfego de origem pode aumentar brevemente."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, %@ için Cloudflare uç sunucusundaki tüm önbelleği temizler. Kaynağa giden trafik kısa süreli artabilir."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "將清空 %@ 在 Cloudflare 邊緣的所有緩存，回源流量會短暫上升。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將清空 %@ 在 Cloudflare 邊緣的所有快取，回源流量會短暫上升。"
          }
        }
      }
    },
