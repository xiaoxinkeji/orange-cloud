    "管理 Worker 的环境变量与密钥，随手增删改。": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أدِر متغيرات البيئة والأسرار لـ Worker — إضافة وتعديل وحذف في أي وقت."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwalte die Umgebungsvariablen und Secrets eines Workers – jederzeit hinzufügen, bearbeiten und entfernen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Manage a Worker’s environment variables and secrets — add, edit, and remove on the fly."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Gestiona las variables de entorno y los secretos de un Worker: agrega, edita y elimina al instante."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gérez les variables d’environnement et les secrets d’un Worker — ajoutez, modifiez et supprimez à la volée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Worker の環境変数とシークレットを管理し、いつでも追加・編集・削除できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Worker의 환경 변수와 시크릿을 관리하고 언제든 추가·편집·삭제하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Gerencie as variáveis de ambiente e os segredos de um Worker: adicione, edite e remova na hora."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Faça a gestão das variáveis de ambiente e dos segredos de um Worker: adicione, edite e remova na hora."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir Worker’ın ortam değişkenlerini ve gizli bilgilerini yönetin — anında ekleyin, düzenleyin ve kaldırın."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "管理 Worker 的環境變數與密鑰，隨手增刪改。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "管理 Worker 的環境變數與密鑰，隨手增刪改。"
          }
        }
      }
    },
