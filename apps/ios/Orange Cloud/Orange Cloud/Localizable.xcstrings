    "当前授权为只读（d1.read），写入语句会被 Cloudflare 拒绝": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التفويض الحالي للقراءة فقط (d1.read). سترفض Cloudflare عبارات الكتابة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Autorisierung ist schreibgeschützt (d1.read). Schreibanweisungen werden von Cloudflare abgelehnt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Authorization is read-only (d1.read). Write statements will be rejected by Cloudflare."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "La autorización es de solo lectura (d1.read). Cloudflare rechazará las sentencias de escritura."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’autorisation est en lecture seule (d1.read). Les instructions d’écriture seront rejetées par Cloudflare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在の認可は読み取り専用（d1.read）です。書き込み文は Cloudflare に拒否されます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 인증은 읽기 전용(d1.read)입니다. 쓰기 문은 Cloudflare에서 거부됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A autorização é somente leitura (d1.read). As instruções de gravação serão rejeitadas pela Cloudflare."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A autorização é apenas de leitura (d1.read). As instruções de escrita serão rejeitadas pela Cloudflare."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yetkilendirme salt okunur (d1.read). Yazma deyimleri Cloudflare tarafından reddedilir."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "目前授權為唯讀（d1.read），寫入語句會被 Cloudflare 拒絕"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "目前授權為唯讀（d1.read），寫入語句會被 Cloudflare 拒絕"
