    "描述太长了，精简后再试。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا الوصف طويل جدًا. اختصره وحاول مرة أخرى."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Beschreibung ist zu lang. Kürze sie und versuche es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That description is too long. Shorten it and try again."
          }
        },
        "es-MX": {
