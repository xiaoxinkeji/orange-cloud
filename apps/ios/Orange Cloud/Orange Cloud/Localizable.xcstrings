    "令牌等同于隧道凭据，请妥善保管，不要公开分享。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الرمز يعادل بيانات اعتماد النفق — احتفظ به بأمان ولا تشاركه علنًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Token entspricht den Tunnel-Anmeldedaten – bewahre es sicher auf und teile es nicht öffentlich."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The token is equivalent to tunnel credentials — keep it safe and don’t share it publicly."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "El token equivale a las credenciales del túnel; guárdalo bien y no lo compartas públicamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le jeton équivaut aux identifiants du tunnel — conservez-le en sécurité et ne le partagez pas publiquement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トークンはトンネルの認証情報に相当します。大切に保管し、公開しないでください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "토큰은 터널 자격 증명과 같습니다. 안전하게 보관하고 공개적으로 공유하지 마세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O token equivale às credenciais do túnel; guarde-o com segurança e não o compartilhe publicamente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O token equivale às credenciais do túnel; guarde-o com segurança e não o partilhe publicamente."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Belirteç, tünel kimlik bilgilerine eşdeğerdir — güvende tutun ve herkese açık paylaşmayın."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "權杖等同於隧道憑證，請妥善保管，不要公開分享。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "權杖等同於通道憑證，請妥善保管，不要公開分享。"
          }
        }
      }
    },
