          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "As regras de acionamento dele também serão removidas. Isto não pode ser anulado."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tetikleme kuralları da kaldırılır. Bu işlem geri alınamaz."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
