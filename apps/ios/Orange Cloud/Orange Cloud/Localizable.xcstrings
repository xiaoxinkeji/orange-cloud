    "复制后未在目标确认到对象，已保留原对象未删除": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر التأكد من وجود الكائن في الوجهة بعد النسخ؛ تم الاحتفاظ بالأصل دون حذفه"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Objekt konnte nach dem Kopieren am Ziel nicht bestätigt werden; das Original wurde behalten und nicht gelöscht"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t confirm the object at the destination after copying; the original was kept and not deleted"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo confirmar el objeto en el destino tras la copia; se conservó el original y no se eliminó"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de confirmer l’objet à la destination après la copie ; l’original a été conservé et non supprimé"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コピー後に宛先でオブジェクトを確認できませんでした。元のオブジェクトは削除せず保持しました"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "복사 후 대상에서 객체를 확인할 수 없습니다. 원본은 삭제하지 않고 유지했습니다"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível confirmar o objeto no destino após a cópia; o original foi mantido e não excluído"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível confirmar o objeto no destino após a cópia; o original foi mantido e não eliminado"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kopyalamadan sonra nesne hedefte doğrulanamadı; orijinal silinmeden korundu"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
