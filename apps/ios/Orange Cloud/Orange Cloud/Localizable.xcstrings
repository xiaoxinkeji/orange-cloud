    "匹配对象创建后不可修改，如需更改请删除后重建。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يمكن تغيير هدف المطابقة بعد الإنشاء؛ احذفه وأعد إنشاءه لتغييره."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Übereinstimmungsziel kann nach der Erstellung nicht geändert werden. Zum Ändern löschen und neu erstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The match target can’t be changed after creation; delete and recreate to change it."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "El objetivo no se puede cambiar después de crearlo; elimínalo y vuelve a crearlo para cambiarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La cible de correspondance ne peut pas être modifiée après sa création ; supprimez-la et recréez-la pour la changer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "対象は作成後に変更できません。変更するには削除して作り直してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "대상은 생성 후 변경할 수 없습니다. 변경하려면 삭제 후 다시 만드세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O alvo não pode ser alterado após a criação; exclua e recrie para alterá-lo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O alvo não pode ser alterado após a criação; elimine e recrie para o alterar."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Eşleşme hedefi oluşturulduktan sonra değiştirilemez; değiştirmek için silip yeniden oluşturun."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "匹配對象建立後不可修改，如需更改請刪除後重建。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "匹配對象建立後不可修改，如需更改請刪除後重建。"
          }
        }
      }
    },
    "匹配的请求将不被缓存。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لن يتم تخزين الطلبات المطابقة مؤقتًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Übereinstimmende Anfragen werden nicht zwischengespeichert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Matching requests will not be cached."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Las solicitudes coincidentes no se almacenarán en caché."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les requêtes correspondantes ne seront pas mises en cache."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一致したリクエストはキャッシュされません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일치하는 요청은 캐시되지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As solicitações correspondentes não serão armazenadas em cache."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Os pedidos correspondentes não serão colocados em cache."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Eşleşen istekler önbelleğe alınmaz."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "符合的請求將不會被緩存。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "符合的請求將不會被快取。"
          }
        }
      }
    },
    "匹配的请求按下方设置进行缓存。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم تخزين الطلبات المطابقة مؤقتًا وفق الإعدادات أدناه."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Übereinstimmende Anfragen werden gemäß den Einstellungen unten zwischengespeichert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Matching requests are cached according to the settings below."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Las solicitudes coincidentes se almacenan en caché según la configuración siguiente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les requêtes correspondantes sont mises en cache selon les réglages ci-dessous."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一致したリクエストは、以下の設定に従ってキャッシュされます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일치하는 요청은 아래 설정에 따라 캐시됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As solicitações correspondentes são armazenadas em cache conforme as configurações abaixo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Os pedidos correspondentes são colocados em cache de acordo com as definições abaixo."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Eşleşen istekler aşağıdaki ayarlara göre önbelleğe alınır."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "符合的請求會依下方設定進行緩存。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "符合的請求會依下方設定進行快取。"
          }
        }
      }
    },
