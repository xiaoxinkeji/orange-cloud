    "同一 IP 在所选时间窗内超过该次数即触发动作。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عندما يتجاوز IP نفسه هذا العدد ضمن النافذة المحددة، يتم تنفيذ الإجراء."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Überschreitet dieselbe IP diese Anzahl im gewählten Zeitfenster, wird die Aktion ausgelöst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When the same IP exceeds this count within the selected window, the action is triggered."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando la misma IP supera este número dentro de la ventana seleccionada, se activa la acción."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque la même IP dépasse ce nombre dans la fenêtre sélectionnée, l’action est déclenchée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同一 IP が選択した時間枠内でこの回数を超えると、アクションが実行されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "동일 IP가 선택한 시간 범위 내에서 이 횟수를 초과하면 작업이 실행됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando o mesmo IP excede essa contagem na janela selecionada, a ação é acionada."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando o mesmo IP excede essa contagem na janela selecionada, a ação é acionada."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aynı IP, seçilen aralıkta bu sayıyı aşarsa işlem tetiklenir."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "同一 IP 在所選時間範圍內超過此次數時即觸發動作。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "同一 IP 在所選時間範圍內超過此次數時即觸發動作。"
          }
        }
      }
    },
