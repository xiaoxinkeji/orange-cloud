          "stringUnit": {
            "state": "translated",
            "value": "點按右上角上傳第一個檔案"
          }
        }
      }
    },
    "点击暂停可冻结画面，连接保持不断开": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انقر على إيقاف مؤقت لتجميد العرض. يبقى الاتصال مفتوحًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe auf Pause, um die Ansicht einzufrieren. Die Verbindung bleibt bestehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap pause to freeze the view. The connection stays open."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca pausa para congelar la vista. La conexión permanece abierta."
