    "Cloudflare Tunnel 的查看与管理（新建隧道、公共主机名路由）属于 Orange Cloud Pro。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عرض Cloudflare Tunnel وإدارته (إنشاء الأنفاق، توجيه أسماء المضيفين العامة) جزء من Orange Cloud Pro."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Anzeigen und Verwalten von Cloudflare Tunnel (Tunnel erstellen, Routing öffentlicher Hostnamen) gehört zu Orange Cloud Pro."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Viewing and managing Cloudflare Tunnel (creating tunnels, public hostname routing) is part of Orange Cloud Pro."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Ver y gestionar Cloudflare Tunnel (crear túneles, enrutamiento por nombre de host público) forma parte de Orange Cloud Pro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’affichage et la gestion de Cloudflare Tunnel (création de tunnels, routage des noms d’hôte publics) font partie d’Orange Cloud Pro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
