            "value": "Controla quais solicitações são armazenadas em cache por string de consulta"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Controla que pedidos são colocados em cache por cadeia de consulta"
          }
        },
        "tr": {
