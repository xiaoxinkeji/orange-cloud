    "用量加载失败，下拉刷新重试": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر تحميل الاستخدام. اسحب للتحديث لإعادة المحاولة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nutzung konnte nicht geladen werden. Zum Aktualisieren ziehen, um es erneut zu versuchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't load usage. Pull to refresh to retry."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo cargar el uso. Desliza para actualizar y reintentar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de charger l’utilisation. Tirez pour actualiser et réessayer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "使用状況を読み込めませんでした。引っ張って再読み込みしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사용량을 불러오지 못했습니다. 아래로 당겨 새로고침하세요."
