    "cloudflared 把命中该主机名的请求转发到这个本地地址。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يوجّه cloudflared الطلبات المطابقة لاسم المضيف هذا إلى هذا العنوان المحلي."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "cloudflared leitet Anfragen, die diesem Hostnamen entsprechen, an diese lokale Adresse weiter."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "cloudflared forwards requests matching this hostname to this local address."
          }
        },
        "es-MX": {
