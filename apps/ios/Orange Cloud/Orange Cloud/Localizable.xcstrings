            "state": "translated",
            "value": "오른쪽 위 +로 새 터널을 만들거나, cloudflared로 만든 뒤 여기서 확인하세요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque em + no canto superior direito para criar um túnel, ou crie um com o cloudflared e veja-o aqui"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque em + no canto superior direito para criar um túnel, ou crie um com o cloudflared e veja-o aqui"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
