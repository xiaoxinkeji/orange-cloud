    "仅显示当前账号最近 30 天的操作记录。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يعرض إجراءات الحساب الحالي خلال آخر 30 يومًا فقط."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeigt nur Aktivitäten des aktuellen Kontos der letzten 30 Tage."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shows only the current account’s activity from the last 30 days."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra solo la actividad de la cuenta actual de los últimos 30 días."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affiche uniquement l’activité du compte actuel sur les 30 derniers jours."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のアカウントの過去 30 日間の操作のみを表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 계정의 지난 30일간 활동만 표시합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostra apenas a atividade da conta atual dos últimos 30 dias."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostra apenas a atividade da conta atual dos últimos 30 dias."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
