    "左滑删除，点按可改动作与备注；匹配对象不可改。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسحب للحذف؛ انقر لتغيير الإجراء والملاحظات. لا يمكن تغيير هدف المطابقة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zum Löschen wischen; zum Ändern von Aktion und Notizen tippen. Das Übereinstimmungsziel kann nicht geändert werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Swipe to delete; tap to change action and notes. The match target can’t be changed."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Desliza para eliminar; toca para cambiar la acción y las notas. El objetivo no se puede cambiar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Balayez pour supprimer ; touchez pour modifier l’action et les notes. La cible de correspondance ne peut pas être modifiée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スワイプで削除、タップでアクションとメモを変更。対象は変更できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스와이프하여 삭제, 탭하여 작업과 메모 변경. 대상은 변경할 수 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Deslize para excluir; toque para alterar a ação e as notas. O alvo não pode ser alterado."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Deslize para eliminar; toque para alterar a ação e as notas. O alvo não pode ser alterado."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Silmek için kaydırın; eylem ve notları değiştirmek için dokunun. Eşleşme hedefi değiştirilemez."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "左滑刪除，點按可改動作與備註；匹配對象不可改。"
