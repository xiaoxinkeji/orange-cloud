    "源站池与健康监测在整个账号内共享，可被多个负载均衡器引用。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُشارَك مجمّعات الأصل ومراقبات الصحة على مستوى الحساب بأكمله ويمكن أن تشير إليها عدة موازِنات تحميل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Origin-Pools und Health-Monitore werden kontoweit geteilt und können von mehreren Load Balancern referenziert werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Origin pools and health monitors are shared across the whole account and can be referenced by multiple load balancers."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Los grupos de origen y los monitores de estado se comparten en toda la cuenta y pueden ser referenciados por varios balanceadores de carga."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les pools d'origine et les moniteurs de santé sont partagés sur tout le compte et peuvent être référencés par plusieurs répartiteurs de charge."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オリジンプールとヘルスモニターはアカウント全体で共有され、複数のロードバランサーから参照できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오리진 풀과 상태 모니터는 계정 전체에서 공유되며 여러 부하 분산기에서 참조할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pools de origem e monitores de integridade são compartilhados em toda a conta e podem ser referenciados por vários balanceadores de carga."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Os pools de origem e os monitores de estado são partilhados em toda a conta e podem ser referenciados por vários balanceadores de carga."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Köken havuzları ve sağlık izleyicileri tüm hesapta paylaşılır ve birden çok yük dengeleyici tarafından kullanılabilir."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "來源池與健康監測在整個帳戶內共用，可被多個負載平衡器引用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "來源池與健康監測在整個帳號內共用，可被多個負載平衡器引用。"
          }
        }
      }
    },
    "源站池是一组后端服务器，供负载均衡器分发流量。点右上角 + 创建。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مجمّع الأصل هو مجموعة من خوادم الواجهة الخلفية يوزّع موازِن التحميل المرور عليها. اضغط + في أعلى اليمين للإنشاء."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Origin-Pool ist eine Gruppe von Backend-Servern, auf die der Load Balancer den Traffic verteilt. Tippe oben rechts auf +, um einen zu erstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An origin pool is a group of backend servers for the load balancer to distribute traffic to. Tap + in the top right to create one."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Un grupo de origen es un conjunto de servidores backend a los que el balanceador de carga distribuye el tráfico. Toca + arriba a la derecha para crear uno."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un pool d'origine est un groupe de serveurs backend vers lesquels le répartiteur de charge distribue le trafic. Touchez + en haut à droite pour en créer un."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オリジンプールは、ロードバランサーがトラフィックを振り分けるバックエンドサーバーのグループです。右上の + で作成できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오리진 풀은 부하 분산기가 트래픽을 분배할 백엔드 서버 그룹입니다. 오른쪽 위 +를 눌러 만드세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um pool de origem é um grupo de servidores de backend para o balanceador de carga distribuir o tráfego. Toque em + no canto superior direito para criar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Um pool de origem é um grupo de servidores de backend para o balanceador de carga distribuir o tráfego. Toque em + no canto superior direito para criar."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Köken havuzu, yük dengeleyicinin trafiği dağıtacağı bir arka uç sunucu grubudur. Oluşturmak için sağ üstteki + simgesine dokunun."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "來源池是一組後端伺服器，供負載平衡器分配流量。點右上角 + 建立。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "來源池是一組後端伺服器，供負載平衡器分配流量。點右上角 + 建立。"
          }
        }
      }
    },
