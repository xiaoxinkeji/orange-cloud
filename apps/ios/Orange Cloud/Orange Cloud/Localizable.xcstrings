    "保存更改。激活通常需几分钟到几小时，最长可达 24 小时。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احفظ تغييراتك. عادةً ما يستغرق التفعيل من بضع دقائق إلى بضع ساعات، حتى 24 ساعة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Speichere deine Änderungen. Die Aktivierung dauert meist einige Minuten bis Stunden, bis zu 24 Stunden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Save your changes. Activation usually takes a few minutes to a few hours, up to 24 hours."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda los cambios. La activación suele tardar de unos minutos a unas horas, hasta 24 horas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistrez vos modifications. L’activation prend généralement de quelques minutes à quelques heures, jusqu’à 24 heures."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "変更を保存します。有効化には通常数分から数時間、最長で 24 時間かかります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "변경 사항을 저장하세요. 활성화는 보통 몇 분에서 몇 시간, 최대 24시간이 걸립니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Salve as alterações. A ativação costuma levar de alguns minutos a algumas horas, até 24 horas."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarde as alterações. A ativação costuma demorar de alguns minutos a algumas horas, até 24 horas."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Değişikliklerinizi kaydedin. Etkinleştirme genellikle birkaç dakikadan birkaç saate, en fazla 24 saate kadar sürer."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "儲存更改。啟用通常需幾分鐘到幾小時，最長可達 24 小時。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "儲存更改。啟用通常需幾分鐘到幾小時，最長可達 24 小時。"
          }
        }
      }
    },
