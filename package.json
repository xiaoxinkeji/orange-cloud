{
  "name": "orange-cloud",
  "private": true,
  "author": "chen2he <z@hz.do>",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://orange-cloud.chatiro.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chen2he/orange-cloud.git"
  },
  "bugs": {
    "url": "https://github.com/chen2he/orange-cloud/issues"
  },
  "scripts": {
    "dev": "turbo dev --filter=web",
    "build": "turbo build",
    "deploy:web": "turbo deploy --filter=web",
    "preview:web": "turbo preview --filter=web",
    "lint": "turbo lint",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@11.5.1",
  "lint-staged": {
    "apps/web/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter=web exec eslint --fix"
    ]
  }
}
